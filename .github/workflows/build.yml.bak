name: Build RPM
permissions:
  contents: write
on:
  workflow_dispatch:
    inputs:
      nginx_version:
        description: "Nginx version, e.g. 1.29.6"
        required: true
        type: string
        default: '1.29.6'

jobs:
  build:
    if: github.event.repository.owner.id == github.event.sender.id
    runs-on: ubuntu-latest
    env:
      ACTIONS_ALLOW_USE_UNSECURE_NODE_VERSION: true
      GITHUB_TOKEN: ${{ secrets.amsternl }}
    container: quay.io/centos/centos:stream10
    steps:
      - name: Checkout
        uses: actions/checkout@v6

      - name: Install build dependencies
        shell: bash
        run: |
          set -euo pipefail
          dnf -y install dnf-plugins-core
          dnf config-manager --set-enabled crb || true
          dnf -y install epel-release || true
          dnf -y install \
            rpm-build \
            rpmdevtools \
            redhat-rpm-config \
            gcc \
            make \
            curl \
            systemd \
            zlib-devel \
            pcre2-devel \
            openssl-devel \
            cmark-devel

      - name: Prepare sources
        shell: bash
        run: |
          set -euo pipefail
          ver="${{ inputs.nginx_version }}"
          sed -i -E "s/^%define base_version .*/%define base_version ${ver}/" SPECS/nginx.spec
          sed -i -E "s/^Version: [0-9.]+[+]/Version: ${ver}+/" SPECS/nginx.spec
          sed -i -E "s/^BASE_VERSION=.*/BASE_VERSION=${ver}/" SPECS/Makefile
          rm -f SOURCES/nginx-*.tar.gz
          curl -fL -o "SOURCES/nginx-${ver}.tar.gz" "https://nginx.org/download/nginx-${ver}.tar.gz"

      - name: Get Env Variables
        run: |
          echo "DT_STAMP=$(date +%Y%m%d%H%M)" >> $GITHUB_ENV
          echo "DateTime=$(date +%d.%m.%Y-%T)" >> $GITHUB_ENV
          echo "REF=${{ github.ref }}" >> $GITHUB_ENV
          echo "REF_NAME=${{ github.ref_name }}" >> $GITHUB_ENV
          echo "GITHUB_RUN_ID=${{ github.run_id }}" >> $GITHUB_ENV
          echo "SHA=${{ github.sha }}" >> $GITHUB_ENV
        continue-on-error: true

      - name: Create Release
        id: create_release
        uses: actions/create-release@latest
        with:
            tag_name: ${{ env.REF_NAME }} #${{ github.run_id }}
            release_name: Release ${{ env.REF_NAME }} #"Release: ${{ env.DT_STAMP }}, nginx version: ${{ inputs.nginx_version }}."
            body: |
              Build width:
              - Date: ${{ env.DateTime }}
              - RUN ID: ${{ env.GITHUB_RUN_ID }}
              - REF: ${{ env.REF }}
              - REF NAME: ${{ env.REF_NAME }}
              - SHA: ${{ env.SHA }}
            draft: false
            prerelease: false
        continue-on-error: true
 
      - name: Build RPM
        id: rpm_build
        shell: bash
        run: |
          set -euo pipefail
          rm -rf ngx_markdown_filter_module
          tar -xzf SOURCES/ngx_markdown_filter_module.tar.gz -C .
          rpmbuild -ba \
            --define "_topdir $(pwd)" \
            --define "_module_dir $(pwd)/ngx_markdown_filter_module" \
            SPECS/nginx.spec

      - name: Upload Release Asset
        id: upload-release-asset 
        uses: actions/upload-release-asset@v1
        with:
             upload_url: ${{ steps.create_release.outputs.upload_url }} # This pulls from the CREATE RELEASE step above, referencing it's ID to get its outputs object, which include a `upload_url`. See this blog post for more info: https://jasonet.co/posts/new-features-of-github-actions/#passing-data-to-future-steps 
             asset_path: ${{ steps.rpm_build.outputs.source_rpm_path }}
             asset_name: ${{ steps.rpm_build.outputs.source_rpm_name }}
             asset_content_type: ${{ steps.rpm_build.outputs.rpm_content_type }}
        continue-on-error: true

      - name: Upload to Release
        uses: softprops/action-gh-release@master
        env:
            GITHUB_TOKEN: ${{ env.GITHUB_TOKEN }}
        with:
          files: |
            RPMS/**/*.rpm
            SRPMS/*.src.rpm
          name: "Unofficial Release: ${{ github.run_id }}, nginx version: ${{ inputs.nginx_version }} // SHA: ${{ env.SHA }} ${{ env.DateTime }}"
          tag_name: ${{ github.ref_name }} #${{ github.run_id }}
          body: |
             Build: ${{ steps.create_release.outputs.release_name }}
             - Date: ${{ env.DateTime }}
             - RUN ID: ${{ env.GITHUB_RUN_ID }}
             - REF: ${{ env.REF }}
             - REF NAME: ${{ env.REF_NAME }}
             - SHA: ${{ env.SHA }}

      - name: Upload artifacts
        id: upload_artifacts
        uses: actions/upload-artifact@v6
        with:
          #nginx-rpms-${{ inputs.nginx_version }}
          #path: ${{ steps.rpm.outputs.rpm_dir_path }}
          name: nginx-rpms-${{ inputs.nginx_version }}
          path: |
            RPMS/**/*.rpm
            SRPMS/*.src.rpm
        continue-on-error: true

      - name: Echo Build Outputs
        shell: bash
        run: |
            echo "${{ steps.rpm_build.outputs }}"
            echo "${{ steps.create_release.outputs }}"
            echo "${{ steps.upload_artifacts.outputs }}"
        continue-on-error: true
